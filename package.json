{
	"name": "svelte-exmarkdown",
	"description": "Svelte component to render markdown. Dynamic and Extensible.",
	"version": "5.0.3",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"package": "svelte-package && node scripts/prebundle.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"clean": "rimraf build coverage dist",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "pnpm run \"/^test:.*/\"",
		"test:playwright": "playwright test",
		"test:vitest": "vitest run",
		"vitest": "vitest",
		"coverage": "vitest run --coverage",
		"lint": "prettier --check --plugin prettier-plugin-svelte . && eslint .",
		"fmt": "prettier --write --plugin prettier-plugin-svelte .",
		"download-testcases": "node -e 'fetch(\"https://spec.commonmark.org/0.30/spec.json\").then(r=>r.text()).then(t=>console.log(`// prettier-ignore\nexport default ${t}`))' > tests/commonmark.ts",
		"changeset": "changeset",
		"release": "pnpm clean && pnpm package && pnpm changeset publish"
	},
	"peerDependencies": {
		"svelte": "^5.1.3"
	},
	"dependencies": {
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unified": "^11.0.5"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@eslint/compat": "^2.0.3",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@shikijs/rehype": "^4.0.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.54.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/svelte": "^5.3.1",
		"@types/mdast": "^4.0.4",
		"@types/node": "^25.4.0",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"esbuild": "^0.27.3",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"highlight.js": "^11.11.1",
		"highlightjs-svelte": "^1.0.6",
		"jsdom": "^28.1.0",
		"katex": "^0.16.38",
		"mermaid": "^11.13.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"rehype-highlight": "^7.0.2",
		"rehype-katex": "^7.0.1",
		"rehype-raw": "^7.0.0",
		"remark-math": "^6.0.0",
		"rimraf": "^6.1.3",
		"shiki": "^4.0.2",
		"svelte": "^5.53.10",
		"svelte-check": "^4.4.5",
		"svelte2tsx": "^0.7.52",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.0.18",
		"water.css": "^2.1.1"
	},
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/ssssota/svelte-exmarkdown.git"
	},
	"homepage": "https://ssssota.github.io/svelte-exmarkdown",
	"keywords": [
		"svelte",
		"markdown",
		"remark",
		"unified",
		"commonmark",
		"gfm",
		"plugin"
	],
	"license": "MIT",
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"files": [
		"dist"
	],
	"svelte": "./dist/index.js",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		"./package.json": "./package.json",
		"./contexts": {
			"types": "./dist/contexts.svelte.d.ts",
			"default": "./dist/contexts.svelte.js"
		},
		"./Markdown.svelte": {
			"types": "./dist/Markdown.svelte.d.ts",
			"svelte": "./dist/Markdown.svelte",
			"default": "./dist/Markdown.svelte"
		},
		"./gfm": {
			"types": "./dist/gfm/index.d.ts",
			"svelte": "./dist/gfm/index.js",
			"default": "./dist/gfm/index.js"
		},
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./Renderer.svelte": {
			"types": "./dist/Renderer.svelte.d.ts",
			"svelte": "./dist/Renderer.svelte",
			"default": "./dist/Renderer.svelte"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"default": "./dist/types.js"
		},
		"./utils": {
			"types": "./dist/utils.d.ts",
			"default": "./dist/utils.js"
		}
	},
	"typesVersions": {
		">4.0": {
			"contexts": [
				"./dist/contexts.svelte.d.ts"
			],
			"Markdown.svelte": [
				"./dist/Markdown.svelte.d.ts"
			],
			"gfm": [
				"./dist/gfm/index.d.ts"
			],
			"index.d.ts": [
				"./dist/index.d.ts"
			],
			"Renderer.svelte": [
				"./dist/Renderer.svelte.d.ts"
			],
			"types": [
				"./dist/types.d.ts"
			],
			"utils": [
				"./dist/utils.d.ts"
			]
		}
	}
}
